# MANIFEST.in for code-muse
# Controls files included in the source distribution (sdist).
# Critical because CI builds wheels from the sdist (not the git checkout).

# Include the entire code_muse package tree (all .py, .pyx, data files, etc.)
graft code_muse

# Root project files required for building and packaging
include LICENSE
include README.md
include pyproject.toml
include uv.lock

# Explicit data files (in case graft is too broad in some environments)
include code_muse/models.json
include code_muse/models_dev_api.json

# === Exclusions for clean sdists ===
prune .git
prune .github
prune .venv
prune build
prune dist
prune *.egg-info
prune .cache
prune .mypy_cache
prune .ruff_cache

# Bytecode and compiled artifacts (never ship these in sdist)
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude *.so
global-exclude *.dll
global-exclude *.dylib

# Other junk
global-exclude .DS_Store
global-exclude *.swp
global-exclude *~
global-exclude .coverage
global-exclude .coverage.*
global-exclude htmlcov
